# ============================================================
# Starline Connectors IMS — Backend Environment Variables
# ============================================================
# Copy this file to .env and fill in your actual values.
# NEVER commit the .env file to version control.
# ============================================================

# --- Server ---
PORT=8080
NODE_ENV=development

# --- Database (Google Cloud SQL PostgreSQL) ---
# Format: postgresql://USER:PASSWORD@HOST:5432/DATABASE
DATABASE_URL=postgresql://ims_user:your_password@your_cloud_sql_ip:5432/starline_ims

# --- JWT ---
JWT_SECRET=your-super-secret-jwt-key-min-32-characters
JWT_EXPIRES_IN=7d

# --- Google Cloud Storage ---
# Bucket name for invoice PDFs (must exist and be private)
GCS_BUCKET_NAME=starline-ims-invoices
# Signed URL expiry in minutes (default: 60)
GCS_SIGNED_URL_EXPIRY_MINUTES=60
# Optional: path to service account key JSON (not needed on Cloud Run with ADC)
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# --- Email (Nodemailer SMTP) ---
# Works with Gmail App Passwords, SendGrid, Mailgun, etc.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-email@gmail.com
SMTP_PASS=your-app-password-or-smtp-password
EMAIL_FROM="Starline Connectors IMS <noreply@starlineconnectors.com>"

# --- Frontend URL (for CORS) ---
FRONTEND_URL=http://localhost:5173

# --- Company Config ---
COMPANY_STATE=Maharashtra
